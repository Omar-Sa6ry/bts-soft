{
  "name": "@bts-soft/common",
  "version": "1.3.1",
  "description": "Shared NestJS utilities (modules, guards, interceptors, decorators, DTOs, and entities) for all @bts-soft packages.",
  "author": "Omar Sabry",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core/bases/AgnosticEntity.js",
    "./typeorm": "./dist/orm/typeorm/TypeOrmBaseEntity.js",
    "./sequelize": "./dist/orm/sequelize/SequelizeBaseEntity.js",
    "./mongoose": "./dist/orm/mongoose/MongooseBaseEntity.js",
    "./prisma": "./dist/orm/prisma/PrismaBase.js",
    "./graphql": "./dist/graphql/bases/GraphqlBaseEntity.js",
    "./interceptors": "./dist/interceptors/generalResponse.interceptor.js",
    "./filters": "./dist/filters/rest-exception.filter.js",
    "./decorators": "./dist/decorators/currentUser.decorator.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "docker-compose -f docker-compose.test.yml up -d && npx jest --passWithNoTests && docker-compose -f docker-compose.test.yml down",
    "test:watch": "npx jest --watch",
    "test:cov": "docker-compose -f docker-compose.test.yml up -d && npx jest --collectCoverage && docker-compose -f docker-compose.test.yml down"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "keywords": [
    "nestjs",
    "graphql",
    "common",
    "decorators",
    "guards",
    "interceptors",
    "dto",
    "entities",
    "shared",
    "typescript",
    "typeorm",
    "sequelize",
    "mongoose",
    "prisma"
  ],
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "ulid": "^3.0.0"
  },
  "peerDependencies": {
    "@apollo/server": ">=4.0.0",
    "@nestjs/apollo": ">=13.0.0",
    "@nestjs/common": ">=11.0.0",
    "@nestjs/config": ">=4.0.0",
    "@nestjs/core": ">=11.0.0",
    "@nestjs/graphql": ">=13.0.0",
    "@nestjs/mongoose": ">=10.0.0",
    "@nestjs/throttler": ">=6.0.0",
    "@prisma/client": ">=5.0.0",
    "graphql": ">=16.0.0",
    "mongoose": ">=7.0.0",
    "nestjs-i18n": ">=10.0.0",
    "sequelize": ">=6.0.0",
    "sequelize-typescript": ">=2.0.0",
    "typeorm": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "@apollo/server": {
      "optional": true
    },
    "@nestjs/apollo": {
      "optional": true
    },
    "@nestjs/config": {
      "optional": true
    },
    "@nestjs/graphql": {
      "optional": true
    },
    "@nestjs/mongoose": {
      "optional": true
    },
    "@nestjs/throttler": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    },
    "graphql": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "nestjs-i18n": {
      "optional": true
    },
    "sequelize": {
      "optional": true
    },
    "sequelize-typescript": {
      "optional": true
    },
    "typeorm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/apollo": "^13.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/graphql": "^13.0.0",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@apollo/server": "^4.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "class-transformer": "^0.5.1",
    "express": "^5.0.0",
    "graphql": "^16.0.0",
    "jest": "^29.5.0",
    "mongoose": "^7.0.0",
    "nestjs-i18n": "^10.4.0",
    "pg": "^8.11.0",
    "mongodb": "^5.0.0",
    "rimraf": "^6.0.0",
    "sqlite3": "^5.0.0",
    "sequelize": "^6.0.0",
    "sequelize-typescript": "^2.0.0",
    "ts-jest": "^29.1.0",
    "typeorm": "^0.3.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.17.0",
    "npm": ">=10.0.0"
  }
}