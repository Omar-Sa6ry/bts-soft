{
  "name": "@bts-soft/cache",
  "version": "1.0.8",
  "description": "A NestJS Redis cache and utility module providing advanced Redis operations, configuration, and health checks with built-in support for CacheManager and Redis client.",
  "author": "Omar Sabry",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "keywords": [
    "nestjs",
    "redis",
    "cache",
    "cache-manager",
    "typescript",
    "redis-service",
    "nestjs-module",
    "bts-soft"
  ],
  "dependencies": {
    "@nestjs/cache-manager": "^2.0.0",
    "cache-manager": "^5.2.4",
    "cache-manager-ioredis": "^2.1.0",
    "ioredis": "^5.3.2",
    "redis": "^4.6.7"
  },
  "peerDependencies": {
    "@nestjs/common": ">=11.0.0",
    "@nestjs/core": ">=11.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.1.19",
    "@types/cache-manager-ioredis": "^2.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.17.0",
    "npm": ">=10.0.0"
  }
}
